datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model BloodInventory {
  id             String   @id @default(uuid())
  bloodType      String   @unique @map("blood_type")
  quantityUnits  Int      @default(0) @map("quantity_units")
  collectionDate String?  @map("collection_date")
  expiryDate     String?  @map("expiry_date")
  updatedAt      String?  @default(dbgenerated("CURRENT_TIMESTAMP")) @map("updated_at")

  @@map("blood_inventory")
}

model Medicine {
  id           String   @id @default(uuid())
  name         String
  category     String
  arrivalDate  String   @map("arrival_date")
  stockArrived Int      @map("stock_arrived")
  stockLeft    Int      @map("stock_left")
  expiryDate   String   @map("expiry_date")
  updatedAt    String?  @default(dbgenerated("CURRENT_TIMESTAMP")) @map("updated_at")

  @@map("medicines")
}

model Department {
  id       String    @id
  name     String    @unique
  patients Patient[]

  @@map("departments")
}

model Patient {
  id               String     @id @default(uuid())
  registrationDate String     @map("registration_date")
  visitType        String     @map("visit_type")
  name             String
  age              Int
  gender           String
  departmentId     String     @map("department_id")
  department       Department @relation(fields: [departmentId], references: [id])
  consultingDoctor String     @map("consulting_doctor")
  updatedAt        String?    @default(dbgenerated("CURRENT_TIMESTAMP")) @map("updated_at")

  @@map("patients")
}

model StaffSection {
  id           String        @id
  name         String        @unique
  staffMembers StaffMember[]

  @@map("staff_sections")
}

model StaffDepartment {
  id           String        @id
  name         String        @unique
  staffMembers StaffMember[]

  @@map("staff_departments")
}

model StaffMember {
  id                String             @id
  name              String
  sectionId         String             @map("section_id")
  section           StaffSection       @relation(fields: [sectionId], references: [id])
  departmentId      String             @map("department_id")
  department        StaffDepartment    @relation(fields: [departmentId], references: [id])
  shift             String
  attendanceRecords AttendanceRecord[]

  @@map("staff_members")
}

model AttendanceRecord {
  id      String      @id @default(uuid())
  staffId String      @map("staff_id")
  staff   StaffMember @relation(fields: [staffId], references: [id])
  date    String
  shift   String
  time    String
  status  String

  @@unique([staffId, date])
  @@map("attendance_records")
}

// Teammate's actual Bed, Room, RoomCategory, Query models
model Bed {
  id          String  @id @default(uuid())
  bedNumber   String  @map("bed_number")
  status      String  @default("Available")
  patientName String? @map("patient_name")
  notes       String?
  roomId      String  @map("room_id")
  room        Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("beds")
}

model Room {
  id         String       @id @default(uuid())
  roomNumber String       @unique @map("room_number")
  status     String       @default("Available")
  categoryId String       @map("category_id")
  category   RoomCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  beds       Bed[]

  @@map("rooms")
}

model RoomCategory {
  id                  String @id @default(uuid())
  roomType            String @unique @map("room_type")
  totalRooms          Int    @default(0) @map("total_rooms")
  bedsPerRoom         Int    @default(0) @map("beds_per_room")
  totalBeds           Int    @default(0) @map("total_beds")
  occupiedBeds        Int    @default(0) @map("occupied_beds")
  availableBeds       Int    @default(0) @map("available_beds")
  occupancyPercentage Int    @default(0) @map("occupancy_percentage")
  rooms               Room[]

  @@map("room_categories")
}

model Query {
  id           String   @id @default(uuid())
  hospitalId   String   @map("hospital_id")
  hospitalName String   @map("hospital_name")
  subject      String
  message      String
  priority     String
  status       String   @default("Pending")
  reply        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("queries")
}
